generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
//   url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  displayName  String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plans                  Plan[]
  sentFriendRequests     Friendship[]     @relation("SentFriendRequests")
  receivedFriendRequests Friendship[]     @relation("ReceivedFriendRequests")
  progressUpdates        ProgressUpdate[]
  comments               Comment[]
  sessions               Session[]
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  requester User @relation("SentFriendRequests", fields: [requesterId], references: [id])
  addressee User @relation("ReceivedFriendRequests", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
}

model Category {
  id    Int     @id @default(autoincrement())
  slug  String  @unique
  label String
  icon  String?

  plans            Plan[]
  sessions         Session[]
  inspirationItems InspirationItem[]
}

enum PlanStatus {
  IDEA
  ACTIVE
  STALLED
  COMPLETED
  ARCHIVED
}

model Plan {
  id           String     @id @default(uuid())
  userId       String
  categoryId   Int
  title        String
  description  String?
  status       PlanStatus @default(IDEA)
  targetDate   DateTime?
  stalledSince DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  category         Category          @relation(fields: [categoryId], references: [id])
  progressUpdates  ProgressUpdate[]
  comments         Comment[]
  planInspirations PlanInspiration[]
  milestones       Milestone[]
}

enum UpdateType {
  TECHNICAL
  QUESTION
  EXTENSION
  SUPPORT
  NONE
}

enum VisibilityLevel {
  PUBLIC
  PRIVATE_TO_AUTHOR
}

model ProgressUpdate {
  id           String          @id @default(uuid())
  planId       String
  userId       String
  content      String
  type         UpdateType      @default(NONE)
  visibility   VisibilityLevel @default(PUBLIC)
  aiClassified Boolean         @default(false)
  createdAt    DateTime        @default(now())

  plan Plan @relation(fields: [planId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Comment {
  id           String          @id @default(uuid())
  planId       String
  userId       String
  content      String
  type         UpdateType      @default(NONE)
  visibility   VisibilityLevel @default(PUBLIC)
  aiClassified Boolean         @default(false)
  createdAt    DateTime        @default(now())

  plan Plan @relation(fields: [planId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

enum SessionIntent {
  BUILD
  EXPLORE
  CONTINUE
}

model Session {
  id              String        @id @default(uuid())
  userId          String
  intent          SessionIntent
  categoryId      Int?
  converted       Boolean       @default(false)
  convertedPlanId String?
  createdAt       DateTime      @default(now())
  endedAt         DateTime?

  user                User                 @relation(fields: [userId], references: [id])
  category            Category?            @relation(fields: [categoryId], references: [id])
  sessionInspirations SessionInspiration[]
}

model InspirationItem {
  id         String @id @default(uuid())
  categoryId Int
  title      String
  body       String?
  imageUrl   String?
  createdAt  DateTime @default(now())

  category            Category             @relation(fields: [categoryId], references: [id])
  sessionInspirations SessionInspiration[]
  planInspirations    PlanInspiration[]
}

model SessionInspiration {
  sessionId     String
  inspirationId String

  session     Session         @relation(fields: [sessionId], references: [id])
  inspiration InspirationItem @relation(fields: [inspirationId], references: [id])

  @@id([sessionId, inspirationId])
}

model PlanInspiration {
  planId        String
  inspirationId String

  plan        Plan            @relation(fields: [planId], references: [id])
  inspiration InspirationItem @relation(fields: [inspirationId], references: [id])

  @@id([planId, inspirationId])
}

model Milestone {
  id          String    @id @default(uuid())
  planId      String
  title       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  plan Plan @relation(fields: [planId], references: [id])
}
